<?xml version="1.0" encoding="UTF-8"?>

<Server port="8081" shutdown="SHUTDOWN">
  <Listener className="org.apache.catalina.core.AprLifecycleListener" SSLEngine="on"/>
  <Service name="Catalina">
    <!--
       The following are defaulted using Unicode Character references.
       Default Relaxed Path Characters:  []|
       Default Relaxed Query Characters: []|{}^`\"<>

       https://tomcat.apache.org/tomcat-8.5-doc/config/ajp.html
       https://tomcat.apache.org/tomcat-8.5-doc/config/http.html
        - maxParameterCount: A value of less than 0 means no limit.
        - maxPostSize: The limit can be disabled by setting this attribute to a value less than zero.
     -->
    <Connector port="8080"
               protocol="HTTP/1.1"
               connectionTimeout="20000"
               compression="off"
               maxHttpHeaderSize="10240"
               maxParameterCount="-1"
               maxPostSize="-1"
               relaxedPathChars="&#x5B;&#x5D;&#x7C;"
               relaxedQueryChars="&#x5B;&#x5D;&#x7C;&#x7B;&#x7D;&#x5E;&#x5C;&#x60;&#x22;&#x3C;&#x3E;"
               redirectPort="8443"
               acceptCount="200"
               maxConnections="1000"
               maxThreads="200"
               URIEncoding="UTF-8">
      <!-- Enable h2c (HTTP/2 cleartext) on the same port as HTTP/1.1.
           Tomcat's Http2Protocol handles both the HTTP/1.1 Upgrade flow and
           h2c-prior-knowledge (the PRI * HTTP/2.0 preface). h2load uses
           prior-knowledge by default; wrk uses HTTP/1.1. -->
      <UpgradeProtocol className="org.apache.coyote.http2.Http2Protocol"/>
    </Connector>
    <!--
       Port 8443: TLS + ALPN HTTP/2 connector.
       Uses Http11Nio2Protocol (JSSE-based NIO) with SSLEnabled=true. The Http2Protocol upgrade
       protocol wired here causes Tomcat to advertise "h2" and "http/1.1" via ALPN during the TLS
       handshake. h2load TLS scenarios target this port.

       Cert paths are relative to catalina.home — at runtime that is benchmarks/tomcat/build/dist/tomcat/apache-tomcat,
       so ../../../../.. walks up to the benchmarks/ directory and certs/ is under that.
     -->
    <Connector port="8443"
               protocol="org.apache.coyote.http11.Http11Nio2Protocol"
               connectionTimeout="20000"
               compression="off"
               maxHttpHeaderSize="10240"
               maxParameterCount="-1"
               maxPostSize="-1"
               SSLEnabled="true"
               scheme="https"
               secure="true"
               acceptCount="200"
               maxConnections="1000"
               maxThreads="200"
               URIEncoding="UTF-8">
      <SSLHostConfig>
        <Certificate certificateFile="${catalina.home}/../../../../../certs/server.crt"
                     certificateKeyFile="${catalina.home}/../../../../../certs/server.key"
                     type="RSA"/>
      </SSLHostConfig>
      <UpgradeProtocol className="org.apache.coyote.http2.Http2Protocol"/>
    </Connector>
    <Engine name="Catalina" defaultHost="localhost">
      <Host name="localhost" autoDeploy="false" unpackWARs="false">
        <Context path="" docBase="${catalina.base}/../web">
          <Manager pathname=""/>
          <Resources allowLinking="true"/>
        </Context>
      </Host>
    </Engine>
  </Service>
</Server>
